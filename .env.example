# Скопируй в .env.local и заполни:

TELEGRAM_BOT_TOKEN=твой_токен_от_BotFather
TELEGRAM_CHAT_ID=твой_id_от_userinfobot

# Как получить TELEGRAM_CHAT_ID:
# 1. Открой https://t.me/userinfobot → Start
# 2. Скопируй число после "Id:" (например 123456789)
# 3. Открой СВОЕГО бота в Telegram → нажми Start
